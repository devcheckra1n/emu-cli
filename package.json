{
  "name": "emu-cli",
  "version": "0.1.0",
  "description": "Terminal-first ROM launcher that searches, downloads (via torrent), and plays games from the MiNERVA Archive.",
  "type": "module",
  "bin": {
    "emu": "./src/index.tsx",
    "emu-cli": "./src/index.tsx"
  },
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun run src/index.tsx",
    "typecheck": "tsc --noEmit",
    "build": "bun build ./src/index.tsx --compile --outfile emu"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "fuse.js": "^7.0.0",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "node-html-parser": "^6.1.13",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "bun-types": "latest",
    "ink-testing-library": "^4.0.0",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.6.3"
  }
}
